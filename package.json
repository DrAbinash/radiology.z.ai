{
  "name": "radiology-zai",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Standalone radiology reporting workstation — pulls studies from Orthanc, launches OHIF/Weasis, AI-assisted reporting via Ollama. Deploy on Synology.",
  "scripts": {
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite --host 0.0.0.0",
    "dev": "concurrently -n server,web -c magenta,blue \"pnpm run dev:server\" \"pnpm run dev:web\"",
    "build:server": "node ./build-server.mjs",
    "build:web": "vite build",
    "build": "pnpm run build:web && pnpm run build:server",
    "start": "cross-env NODE_ENV=production node --enable-source-maps ./dist/server/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:push": "drizzle-kit push --config ./drizzle.config.ts",
    "seed": "tsx scripts/seed-defaults.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.36.4",
    "express": "^4.21.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.30.4",
    "esbuild": "^0.27.3",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.545.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.2",
    "vite": "^7.3.2",
    "wouter": "^3.3.5"
  }
}
