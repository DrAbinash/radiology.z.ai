# ── Database ────────────────────────────────────────────────────────────────
RAD_DB_USER=radiology
RAD_DB_PASSWORD=change-this-to-a-strong-password
RAD_DB_NAME=radiology
RAD_HOST_PORT=3002

# ── Orthanc (on your Synology NAS) ──────────────────────────────────────────
# The PACS where studies live. Both the ERP and this service read from it.
ORTHANC_URL=http://192.168.1.100:8042
ORTHANC_USER=
ORTHANC_PASSWORD=

# ── Viewers (open on the user's laptop) ─────────────────────────────────────
# OHIF: leave empty to use Orthanc's built-in viewer. Or set to a local OHIF:
#   OHIF_URL=http://localhost:3004
OHIF_URL=
# Weasis: desktop app launched via weasis:// protocol (must be installed on laptop)
WEASIS_URL=weasis://
# DICOMweb endpoint (where viewers fetch images). Usually Orthanc's /dicom-web:
DICOM_WEB_URL=http://192.168.1.100:8042/dicom-web

# ── Ollama AI (optional — Windows PC on LAN) ────────────────────────────────
OLLAMA_URL=http://192.168.1.50:11434
OLLAMA_MODEL=llama3.2

# ── ERP boundary (optional — for patient demographics + delivery sync) ──────
# Leave empty to run fully standalone. Set to push finalized reports to ERP.
ERP_API_URL=
BOUNDARY_API_KEY=

# ── HTTPS ────────────────────────────────────────────────────────────────────
# Leave as false unless you've put a reverse proxy with a real TLS
# certificate in front of this app (e.g. Synology's built-in Reverse Proxy +
# Let's Encrypt, or a Synology domain via DDNS). If you access the app as
# plain http://<nas-ip>:3002 (the normal case), leave this false — setting
# it true will break login, since browsers won't store secure cookies over
# plain HTTP.
HTTPS_ENABLED=false

# ── 2 Users (you + your wife) ───────────────────────────────────────────────
ADMIN_USERNAME=abinash
ADMIN_PASSWORD=change-this
ADMIN_NAME=Dr. Abinash Kumar
RADIOLOGIST_USERNAME=sugandha
RADIOLOGIST_PASSWORD=change-this
RADIOLOGIST_NAME=Dr. Sugandha Priyadarshini
